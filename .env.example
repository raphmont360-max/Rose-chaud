# Mot de passe admin — copiez vers .env.local et choisissez votre propre secret
# Agenda : /admin/agenda
# Témoignages : /admin/temoignages
ADMIN_SECRET=choisissez-un-mot-de-passe-secret

# Resend — formulaire de contact (https://resend.com)
# Clé API : Dashboard → API Keys → Create
RESEND_API_KEY=re_xxxxxxxx
# Boîte qui reçoit les demandes de devis
# Sans domaine vérifié : doit être l'email du compte Resend (ex. vous@gmail.com)
# Avec domaine vérifié : contact.rosechaud@gmail.com ou toute autre adresse
CONTACT_TO_EMAIL=raphmont360@gmail.com
# Au début : onboarding@resend.dev (compte Resend gratuit)
# Plus tard, avec domaine vérifié : Rose chaud <contact@votredomaine.fr>
RESEND_FROM=Rose chaud <onboarding@resend.dev>
