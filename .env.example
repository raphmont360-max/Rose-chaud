# Mot de passe admin — copiez vers .env.local et choisissez votre propre secret
# Agenda : /admin/agenda
# Témoignages : /admin/temoignages
ADMIN_SECRET=choisissez-un-mot-de-passe-secret

# Resend — formulaire de contact (https://resend.com)
# Compte Resend : contact.rosechaud@gmail.com (obligatoire en mode test)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Rose chaud <onboarding@resend.dev>
# Les devis arrivent sur contact.rosechaud@gmail.com ; un accusé part aussi au client
# En mode test (onboarding@resend.dev), l'accusé client ne part qu'avec un domaine vérifié sur Resend
